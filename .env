OPENAI_API_KEY=your-api-key-here
PHOENIX_ENDPOINT=http://localhost:6006/v1/traces
PHOENIX_PROJECT_NAME=nasa-mission-intelligence

# Redis / broker defaults (enabled)
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
EVALUATION_BROKER_ENABLED=true
JUDGE_BROKER_ENABLED=true

# Service identity / API behavior
OTEL_SERVICE_NAME=nasa-mission-intelligence
ALLOWED_ORIGINS=localhost:3000,localhost:8000

# Judge / evaluation mode
JUDGE_MODE_DEFAULT=async
JUDGE_TIMEOUT_SECONDS=2.5
EVALUATION_MODE=async

# Runtime modes (balanced profile)
PREFLIGHT_RETRIEVAL_MODE=fastest
EVALUATION_LOCAL_FALLBACK_ENABLED=true

# Stage timeouts (seconds)
RETRIEVAL_TIMEOUT_SECONDS=3.5
GENERATION_TIMEOUT_SECONDS=6.5
EVALUATION_TIMEOUT_SECONDS=3.0

# Circuit breaker
STAGE_BREAKER_FAILURE_THRESHOLD=5
STAGE_BREAKER_RECOVERY_SECONDS=30

# Dynamic retrieval depth
RETRIEVAL_FACTOID_N_RESULTS=2
RETRIEVAL_BROAD_N_RESULTS=4

# Context compression
CONTEXT_MAX_TOKENS=2000
CONTEXT_DEDUP_THRESHOLD=0.85

# Latency budgets (ms)
PREFLIGHT_BUDGET_MS=20
RETRIEVAL_BUDGET_MS=1500
GENERATION_BUDGET_MS=5000

# Stage pool sizing (medium traffic profile)
SAFETY_WORKERS=3
RETRIEVAL_WORKERS=8
GENERATION_WORKERS=8
JUDGE_WORKERS=2
EVALUATION_WORKERS=2

# Stage queue limits (medium traffic profile)
SAFETY_QUEUE_LIMIT=240
RETRIEVAL_QUEUE_LIMIT=600
GENERATION_QUEUE_LIMIT=600
JUDGE_QUEUE_LIMIT=160
EVALUATION_QUEUE_LIMIT=300
STAGE_QUEUE_SUBMIT_TIMEOUT_SECONDS=0.05

# Stage SLI event store
STAGE_SLI_LOG_FILE=./monitoring/stage_latency_events.jsonl
STAGE_SLI_RETENTION_HOURS=168
STAGE_SLI_MAX_FILE_BYTES=20971520
STAGE_SLI_MAX_ROTATED_FILES=10
STAGE_SLI_MAINTENANCE_SECONDS=60
